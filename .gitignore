# ══════════════════════════════════════════════════════════════
#  ExtensFlow — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Segredos e variáveis de ambiente ─────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
*.env

# ── Java / Maven ──────────────────────────────────────────────
backend/target/
backend/*.jar
backend/*.war
backend/*.ear
backend/*.class
backend/hs_err_pid*
backend/.mvn/wrapper/maven-wrapper.jar

# ── Spring Boot ───────────────────────────────────────────────
backend/src/main/resources/application-prod.properties
backend/src/main/resources/application-local.properties
backend/logs/
logs/
*.log
*.log.*

# ── Node / npm ────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.cache/
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# ── IDEs ──────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
*.launch
.factorypath

.vscode/
*.code-workspace
.history/

*.swp
*.swo
*~

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Linux ─────────────────────────────────────────────────────
*~
.fuse_hidden*
.Trash-*
.nfs*

# ── Docker ────────────────────────────────────────────────────
docker-compose.override.yml

# ── Testes e cobertura ────────────────────────────────────────
backend/target/surefire-reports/
backend/target/site/
frontend/coverage/
frontend/.nyc_output/

# ── Misc ──────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej
.sass-cache/
